<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="CampusCuisine.Views.MenuItemView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:CampusCuisine.Models"
    x:Name="ThisView">

  <CollectionView ItemsSource="{Binding Source={x:Reference ThisView}, Path=Items}">
    <CollectionView.ItemTemplate>
      <DataTemplate x:DataType="model:MenuItemModel">
        <Frame Margin="10" Padding="10">
          <VerticalStackLayout Spacing="8">

            <Image Source="{Binding ImageUrl}"
                               Aspect="AspectFill"
                               HeightRequest="180" />

            <Label Text="{Binding Name}"
                               FontAttributes="Bold"
                               FontSize="18" />

            <Label Text="{Binding Description}"
                               FontSize="14" />

            <Label Text="{Binding Price, StringFormat='£{0:F2}'}"
                               FontSize="16" />

            <Button Text="Add"
                                Clicked="OnAddClicked"
                                CommandParameter="{Binding .}" />

          </VerticalStackLayout>
        </Frame>
      </DataTemplate>
    </CollectionView.ItemTemplate>
  </CollectionView>
</ContentView>