<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CampusCuisine.Pages.MainsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Mains"
    BackgroundColor="White">

  <Grid RowDefinitions="Auto,*" Padding="20">
    <Label
      Text="Mains"
      FontSize="28"
      FontAttributes="Bold"
      Grid.Row="0"
      Margin="0,0,0,15" />

    <CollectionView
      Grid.Row="1"
      ItemsSource="{Binding Items}">
      <CollectionView.ItemTemplate>
        <DataTemplate>
          <Border
            Stroke="Black"
            StrokeShape="0"
            Padding="10"
            Margin="0,0,0,12">

            <Grid ColumnDefinitions="90,*" ColumnSpacing="12">

              <Border
                Grid.Column="0"
                Stroke="Black"
                StrokeThickness="1"
                HeightRequest="80"
                WidthRequest="80"
                BackgroundColor="Transparent">
                <Grid>
                  <Label
                    Text="Image"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
                </Grid>
              </Border>

              <VerticalStackLayout
                Grid.Column="1"
                Spacing="6"
                VerticalOptions="Center">

                <Label
                  Text="{Binding Name}"
                  FontSize="18"
                  FontAttributes="Bold"
                  LineBreakMode="TailTruncation" />

                <BoxView HeightRequest="1" BackgroundColor="Black" />

                <Label
                  Text="{Binding Description}"
                  FontSize="14"
                  LineBreakMode="WordWrap" />

                <Label
                  Text="{Binding Price}"
                  FontSize="16"
                  FontAttributes="Bold"
                  HorizontalOptions="End" />
              </VerticalStackLayout>

            </Grid>
          </Border>
        </DataTemplate>
      </CollectionView.ItemTemplate>
    </CollectionView>
  </Grid>
</ContentPage>