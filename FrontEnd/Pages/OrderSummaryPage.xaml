<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CampusCuisine.Pages.OrderSummaryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:CampusCuisine.Models"
    Title="Order Summary">

  <ScrollView>
    <VerticalStackLayout Padding="20" Spacing="16">

      <Label Text="Order Summary"
                   FontSize="24"
                   FontAttributes="Bold" />

      <CollectionView ItemsSource="{Binding OrderItems}">
        <CollectionView.EmptyView>
          <Label Text="Your order is empty." />
        </CollectionView.EmptyView>

        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="model:MenuItemModel">
            <Frame Padding="10" Margin="0,4">
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{Binding Name}"
                                       FontAttributes="Bold" />

                <Label Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding Price, StringFormat='£{0:F2}'}" />

                <Label Grid.Row="1"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding Description}"
                                       FontSize="12" />
              </Grid>
            </Frame>
          </DataTemplate>
        </CollectionView.ItemTemplate>
      </CollectionView>

      <Label Text="{Binding TotalItemsText}"
                   FontAttributes="Bold" />

      <Button Text="Place Order"
                    Clicked="OnPlaceOrderClicked" />

      <Label Text="{Binding ResultMessage}"
                   TextColor="Green" />

      <Label Text="{Binding ErrorMessage}"
                   TextColor="Red" />

    </VerticalStackLayout>
  </ScrollView>
</ContentPage>