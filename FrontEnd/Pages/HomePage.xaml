<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CampusCuisine.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Home"
    BackgroundColor="White">

  <ScrollView>
    <VerticalStackLayout Padding="20" Spacing="20">

      <Border
        Stroke="Black"
        StrokeShape="0"
        Padding="20">

        <VerticalStackLayout Spacing="15">
          <Label
            Text="Welcome to Campus Cuisine"
            FontSize="28"
            FontAttributes="Bold"
            HorizontalOptions="Center" />

          <BoxView HeightRequest="1" BackgroundColor="Black" />

          <Label
            Text="Welcome to Campus Cuisine. Use the flyout navigation to browse Starters, Mains, and Desserts."
            FontSize="16" />

        </VerticalStackLayout>
      </Border>
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>