<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CampusCuisine.Pages.DessertsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CampusCuisine.Views"
    Title="Desserts"
    BackgroundColor="White">

  <Grid RowDefinitions="Auto,*" Padding="20">
    <Label
            Text="Desserts"
            FontSize="28"
            FontAttributes="Bold"
            TextColor="Black"
            Grid.Row="0"
            Margin="0,0,0,15" />

    <views:MenuItemView
            Grid.Row="1"
            Items="{Binding MenuItems}" />
  </Grid>
</ContentPage>